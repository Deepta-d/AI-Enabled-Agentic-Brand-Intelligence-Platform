MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=sentiment_brand_intel

# If the password contains @ : / # or spaces, that is fine — Phase 1 URL-encodes it.
# Do not wrap the password in quotes unless the quotes are part of the password.

# --- Phase 3: Unified MCP + agents + Streamlit HITL ---
# Draft alerts are always logged. Real sends only when ALERTS_ENABLED=true
# AND a human Approves in the Streamlit chatbot.
ALERTS_ENABLED=false

# Gmail SMTP (App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=your.email@gmail.com
ALERT_EMAIL_TO=ops@example.com

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+10000000000

# Optional FRED enrichment (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# LLM — primary Ollama (free local), fallback Gemini 2.5 Flash (free API key)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest

# Fallback when Ollama is down / times out / fails
# Free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

LLM_TEMPERATURE=0
TOOL_CACHE_TTL_SECONDS=300

# Optional cloud LLMs (only used if LLM_PROVIDER=openai or anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
